{
  "semi": true,
  "trailingComma": "es5",
  "singleQuote": false,
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "proseWrap": "preserve",
  "plugins": ["prettier-plugin-gherkin"],
  "overrides": [
    {
      "files": "*.feature",
      "options": {
        "parser": "gherkin"
      }
    }
  ]
}
